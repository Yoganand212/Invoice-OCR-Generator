generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Invoice {
  id            String   @id @default(uuid())
  filename      String
  originalPath  String
  extractedText String?
  invoiceNumber String?
  invoiceDate   String?
  vendorName    String?
  gstNumber     String?
  totalAmount   String?
  createdAt     DateTime @default(now())
}
